{
  "name": "server-manager-portal",
  "version": "1.6.0",
  "description": "A web application to automatically manage Plex user access based on expiry dates.",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "clean:static": "node scripts/clean-static-build.cjs",
    "build:css": "npx tailwindcss -i ./input.css -o ./static/tailwind.css",
    "build:js": "npm run clean:static && esbuild index.tsx --bundle --outdir=static --splitting --jsx=automatic --format=esm",
    "build:version": "node build-version.js && node build-release-notes.js",
    "build": "npm run build:css && npm run build:js && npm run build:version",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "start": "npm run build && node --env-file=.env index.js",
    "start:prod": "node index.js"
  },
  "dependencies": {
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.7",
    "esbuild": "^0.28.1",
    "express": "^4.19.2",
    "html2canvas": "^1.4.1",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.21.0",
    "node-fetch": "^3.3.2",
    "nodemailer": "^9.0.1",
    "recharts": "^3.9.0",
    "sharp": "^0.35.3"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "vitepress": "^1.6.4"
  }
}
